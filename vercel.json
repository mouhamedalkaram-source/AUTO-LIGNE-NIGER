{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "api/router.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/router"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/router?path=$1"
    }
  ]
}
